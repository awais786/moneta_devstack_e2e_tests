# =============================================================================
# E2E suite configuration
# =============================================================================
# This suite is environment-agnostic. The single mandatory URL is
# FOSS_BASE_URL — everything else (per-app hosts, ForwardAuth host, cookie
# domain) is derived from it using the FOSS naming convention:
#
#   FOSS_BASE_URL=https://foss.<domain>
#       → main portal
#       → ForwardAuth = foss-auth.<domain>
#       → Outline     = foss-docs.<domain>
#       → Plane (PM)  = foss-pm.<domain>
#       → Penpot      = foss-design.<domain>
#       → SurfSense   = foss-research.<domain>
#       → cookie scope = .<domain>
# =============================================================================

# --- Required: SSO credentials ---
FOSS_USER=you@arbisoft.com
FOSS_PASS=your_password_here

# --- Optional: Plane god-mode admin credentials ---
# Required for tests/apps/pm-godmode.spec.ts admin sign-in test.
# Test self-skips if these are unset.
# PLANE_ADMIN_USER=admin@example.com
# PLANE_ADMIN_PASS=your_admin_password

# --- Optional: Outline admin SSO credentials ---
# Separate SSO user with role=admin in Outline. Enables the
# admin-reaches-every-settings-page block in tests/apps/outline-admin.spec.ts.
# Block self-skips if these are unset.
# OUTLINE_ADMIN_USER=outline-admin@example.com
# OUTLINE_ADMIN_PASS=your_admin_password

# --- Optional: Penpot admin SSO credentials ---
# SSO user who is owner or admin on at least one Penpot team. Enables
# tests/apps/penpot-admin.spec.ts (promote a teammate via RPC, verify,
# restore). The spec self-skips if these are unset; the test itself
# also skips if the admin's teams contain no member safe to mutate
# (need a non-self, non-owner teammate).
# PENPOT_ADMIN_USER=penpot-admin@example.com
# PENPOT_ADMIN_PASS=your_admin_password

# --- Optional: SurfSense Owner SSO credentials ---
# SSO user who is Owner of at least one SurfSense SearchSpace. Enables
# tests/apps/surfsense-admin.spec.ts (promote a teammate via the RBAC
# PUT /searchspaces/<id>/members/<id> endpoint, verify, restore). Spec
# self-skips if unset; test also skips when no safe (non-self,
# non-Owner) member is available.
# SURFSENSE_ADMIN_USER=surfsense-admin@example.com
# SURFSENSE_ADMIN_PASS=your_admin_password

# --- Optional: Twenty admin SSO credentials ---
# SSO user with User.canAccessFullAdminPanel=true in Twenty. Enables
# the admin-side test in tests/apps/twenty-admin.spec.ts (verifies the
# admin /settings/admin-panel renders admin UI markers for this user).
# Twenty has NO first-user-auto-admin — the bootstrap CLI command
# `workspace:bootstrap-sso-admin --email <email>` (wired by the
# foss-server-bundle-devstack provisioner) is the only way to promote.
# So this account must be pre-bootstrapped on the deployment.
# Block self-skips if unset.
# TWENTY_ADMIN_USER=twenty-admin@example.com
# TWENTY_ADMIN_PASS=your_admin_password

# --- Optional: target deployment ---
# Default: sandbox at foss.arbisoft.com.
# Switch to a different deployment (staging, prod, local) with this single line:
# FOSS_BASE_URL=https://foss.example.com

# --- Optional: browser selection ---
# Default (unset) → chromium only.
#   all                        → chromium + firefox + webkit
#   chromium | firefox | webkit
#   comma-separated list, e.g. firefox,webkit
# BROWSERS=all

# --- Optional: IDP overrides ---
# IDPs differ per deployment and aren't derivable from FOSS_BASE_URL.
# Defaults match the sandbox.
# FOSS_COGNITO_DOMAIN=amazoncognito.com
# FOSS_MPASS_DOMAIN=moneta-auth.sandbox.pressingly.net
# FOSS_IDP_HOSTS=amazoncognito.com,moneta-auth.sandbox.pressingly.net

# --- Optional: SSO cookie name override ---
# FOSS_AUTH_COOKIE=_oauth2_proxy
