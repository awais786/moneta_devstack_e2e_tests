# --- Required: SSO credentials ---
FOSS_USER=you@arbisoft.com
FOSS_PASS=your_password_here

# --- Optional: browser selection ---
# Default (unset) → chromium only.
# Accepted values:
#   all                       → chromium + firefox + webkit
#   chromium | firefox | webkit
#   comma-separated list, e.g. firefox,webkit
# BROWSERS=all

# --- Optional: target environment ---
# All hosts/cookies default to the production FOSS deployment.
# Override only when targeting staging, an ephemeral env, or local.
#
# Main portal
# FOSS_BASE_URL=https://foss.arbisoft.com
#
# oauth2-proxy ForwardAuth host
# FOSS_AUTH_PROXY=foss-auth.arbisoft.com
#
# oauth2-proxy session cookie name
# FOSS_AUTH_COOKIE=_oauth2_proxy
#
# Identity providers (comma-separated). Defaults to FOSS_COGNITO_DOMAIN + FOSS_MPASS_DOMAIN.
# FOSS_IDP_HOSTS=amazoncognito.com,moneta-auth.sandbox.pressingly.net
# FOSS_COGNITO_DOMAIN=amazoncognito.com
# FOSS_MPASS_DOMAIN=moneta-auth.sandbox.pressingly.net
#
# Per-app URLs
# FOSS_APP_OUTLINE=https://foss-docs.arbisoft.com
# FOSS_APP_PM=https://foss-pm.arbisoft.com
# FOSS_APP_PENPOT=https://foss-design.arbisoft.com
# FOSS_APP_SURFSENSE=https://foss-research.arbisoft.com
